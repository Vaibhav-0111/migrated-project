# ============================================
# YOUR OWN ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ============================================

# --- FIREBASE (Authentication) ---
# Get from: https://console.firebase.google.com
# → Your Project → Project Settings → Your Apps → Web App → Config
VITE_FIREBASE_API_KEY=AIzaSy_YOUR_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# --- SUPABASE (Database only — questions, stats, games) ---
# Keep your existing Supabase project OR create a new one at supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
